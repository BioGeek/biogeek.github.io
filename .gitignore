__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

/.quarto/

**/*.quarto_ipynb
# Collision-suffixed intermediates left by overlapping/interrupted renders.
**/*.quarto_ipynb_*

# Rendered site (built and deployed by GitHub Actions, not committed)
/docs/

# RenderCV artifacts: keep only the downloadable PDF tracked, ignore the rest
/files/jeroen-van-goey-cv.typ
/files/jeroen-van-goey-cv.md
/files/jeroen-van-goey-cv.html
/files/jeroen-van-goey-cv_*.png

# Listing thumbnails generated on every render by the freeze:false data posts.
# They are regenerated locally and in CI (and would otherwise make the daily
# update workflows churn binary diffs), so they are not committed. The
# freeze:auto posts' thumbnails (pruning.png, theoretical-spectrum.png) ARE
# committed, because their cells don't re-run in CI.
/posts/inaturalist-sightings/inat-by-group.png
/posts/trail-running-strava/strava-monthly.png
/posts/trail-running-strava/strava-routes.png
/posts/trails-and-sightings/crossover-map.png

# Quarto listing / RSS render intermediates for the Writing page (regenerated
# on every render; not committed).
/writing-listing.json
/writing.feed-full-staged

# Local agent / skill tooling
/.claude/
/.agents/
/skills-lock.json
